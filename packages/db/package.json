{
  "name": "@cel/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "echo \"(db) source-only package — consumed as TS, no build\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@cel/types": "workspace:*",
    "drizzle-orm": "0.38.3",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@cel/config": "workspace:*",
    "drizzle-kit": "0.30.1",
    "tsx": "4.19.2"
  }
}
