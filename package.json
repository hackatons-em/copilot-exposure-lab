{
  "name": "copilot-exposure-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Microsoft-native security product that safely tests whether M365 Copilot, Copilot Studio agents, and SharePoint/OneDrive permissions could expose sensitive data.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "dev": "pnpm -r --parallel --if-present dev",
    "seed:demo": "pnpm --filter @cel/worker seed:demo",
    "demo:run": "pnpm --filter @cel/worker demo:run"
  },
  "devDependencies": {
    "@eslint/js": "9.18.0",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vitest": "2.1.8"
  }
}
